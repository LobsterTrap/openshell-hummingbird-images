# OpenShell Supervisor — Hummingbird Edition
#
# Rebased onto quay.io/hummingbird/core-runtime (distroless, near-zero CVE).
# Original base: nvcr.io/nvidia/base/ubuntu:noble-20251013
#
# The supervisor binary is staged by CI before the image build:
#   .build/binaries/<arch>/openshell-sandbox
#
# Build (after staging binary):
#   podman build -f core/supervisor/Containerfile -t supervisor .

ARG HUMMINGBIRD_CORE_RUNTIME_BUILDER=quay.io/hummingbird/core-runtime@sha256:0b8d9bedb57a38c85f680ab05e3e84f0f8c3d04b4bdd1e571a83a58e62ed5551
ARG HUMMINGBIRD_CORE_RUNTIME=quay.io/hummingbird/core-runtime@sha256:63cca59f158e8b262a516997f9419047501b50c5f4729a2479b89de9e881571b

# ---------------------------------------------------------------------------
# Builder stage: create openshell user (distroless has no useradd)
# ---------------------------------------------------------------------------
FROM ${HUMMINGBIRD_CORE_RUNTIME_BUILDER} AS usersetup

# Hummingbird builder images default to non-root; need root for useradd
USER root
RUN useradd --create-home --user-group --uid 1001 openshell

# ---------------------------------------------------------------------------
# Final supervisor image (distroless)
# ---------------------------------------------------------------------------
FROM ${HUMMINGBIRD_CORE_RUNTIME}

ARG TARGETARCH

# Import user/group entries from builder
COPY --from=usersetup /etc/passwd /etc/passwd
COPY --from=usersetup /etc/group /etc/group
COPY --from=usersetup /etc/shadow /etc/shadow
COPY --from=usersetup --chown=1001:1001 /home/openshell /home/openshell

WORKDIR /app

# Supervisor binary (pre-built by CI for the target arch)
COPY --chmod=755 .build/binaries/${TARGETARCH}/openshell-sandbox /usr/local/bin/openshell-sandbox

USER openshell

ENTRYPOINT ["openshell-sandbox"]
